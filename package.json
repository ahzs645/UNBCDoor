{
  "name": "unbc-door-sign-generator",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "test": "node --test",
    "preview": "vite preview",
    "compare-sign": "python3 tools/compare_door_sign.py",
    "compare-all": "python3 tools/prepare_archive_compare.py && vite build --config tools/compare-viewer/vite.config.js && python3 tools/inline_compare_build.py",
    "deploy": "npm run build && gh-pages -d dist"
  },
  "dependencies": {
    "html2canvas": "^1.4.1",
    "jspdf": "^3.0.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "svg2pdf.js": "^2.5.0"
  },
  "devDependencies": {
    "@types/node": "^24.0.13",
    "@types/react": "^18.2.15",
    "@types/react-dom": "^18.2.7",
    "@vitejs/plugin-react": "^6.0.2",
    "postcss": "^8.5.6",
    "vite": "^8.0.16"
  }
}
